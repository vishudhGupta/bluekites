{% liquid
	assign default_button_label = section.settings.button_label | default: 'Shop now'
%}

<section
	id="FeatureProducts-{{ section.id }}"
	class="feature-products color-{{ section.settings.color_scheme }}"
	style="
		--fp-bg: {{ section.settings.background_color }};
		--fp-heading: {{ section.settings.heading_color }};
		--fp-text: {{ section.settings.text_color }};
		--fp-button-bg: {{ section.settings.button_bg }};
		--fp-button-text: {{ section.settings.button_text }};
		--fp-card-radius: {{ section.settings.card_radius }}px;
		--fp-card-gap: {{ section.settings.card_gap }}px;
		--fp-expanded-flex: {{ section.settings.expanded_ratio | divided_by: 10.0 }};
		--fp-collapsed-flex: {{ section.settings.collapsed_ratio | divided_by: 10.0 }};
		--fp-padding-top: {{ section.settings.padding_top }}px;
		--fp-padding-bottom: {{ section.settings.padding_bottom }}px;
	"
>
	<div class="page-width-normal feature-products__inner">
		<header class="feature-products__head">
			<div class="feature-products__head-text">
				{% if section.settings.heading != blank %}
					<h2 class="feature-products__heading">{{ section.settings.heading }}</h2>
				{% endif %}
				{% if section.settings.subheading != blank %}
					<p class="feature-products__subheading">{{ section.settings.subheading }}</p>
				{% endif %}
			</div>

			<button class="feature-products__next" type="button" data-next aria-label="Next product">
				<span>&rarr;</span>
			</button>
		</header>

		<div class="feature-products__carousel" data-carousel>
			{% assign first_product = blank %}
			{% for block in section.blocks %}
				{% assign product = block.settings.product %}
				{% if product != blank %}
					{% if first_product == blank %}
						{% assign first_product = product %}
					{% endif %}

					<article
						class="feature-products__card{% if forloop.first %} is-active{% endif %}"
						data-card
						data-index="{{ forloop.index0 }}"
						data-title="{{ product.title | escape }}"
						data-price="{{ product.price | money | escape }}"
						data-url="{{ product.url }}"
						{{ block.shopify_attributes }}
					>
						<a href="{{ product.url }}" class="feature-products__card-link">
							<div class="feature-products__media-wrap">
								{% if product.featured_media != blank %}
									{{
										product.featured_media
										| image_url: width: 2000
										| image_tag:
											widths: '360, 540, 720, 960, 1280, 1600, 2000',
											sizes: '(max-width: 749px) 72vw, (max-width: 1199px) 42vw, 30vw',
											class: 'feature-products__image',
											loading: 'lazy',
											alt: product.title
									}}
								{% else %}
									{{ 'product-apparel-1' | placeholder_svg_tag: 'feature-products__image feature-products__image--placeholder' }}
								{% endif %}

								{% if block.settings.badge_text != blank %}
									<span class="feature-products__badge">{{ block.settings.badge_text }}</span>
								{% endif %}
							</div>
						</a>
					</article>
				{% endif %}
			{% endfor %}
		</div>

		<div class="feature-products__details" data-details>
			{% if first_product != blank %}
				<h3 class="feature-products__title" data-active-title>{{ first_product.title }}</h3>
				<p class="feature-products__price" data-active-price>{{ first_product.price | money }}</p>
				<a class="feature-products__cta" data-active-link href="{{ first_product.url }}">{{ default_button_label }}</a>
			{% else %}
				<p class="feature-products__empty">Add product blocks to show featured products.</p>
			{% endif %}
		</div>
	</div>
</section>

<script>
	(() => {
		const sectionEl = document.getElementById('FeatureProducts-{{ section.id }}');
		if (!sectionEl) return;

		const cards = [...sectionEl.querySelectorAll('[data-card]')];
		if (!cards.length) return;

		const nextButton = sectionEl.querySelector('[data-next]');
		const titleEl = sectionEl.querySelector('[data-active-title]');
		const priceEl = sectionEl.querySelector('[data-active-price]');
		const linkEl = sectionEl.querySelector('[data-active-link]');

		let activeIndex = Math.max(
			0,
			cards.findIndex((card) => card.classList.contains('is-active'))
		);

		const setActive = (nextIndex) => {
			activeIndex = (nextIndex + cards.length) % cards.length;

			cards.forEach((card, index) => {
				card.classList.toggle('is-active', index === activeIndex);
			});

			const active = cards[activeIndex];
			if (titleEl) titleEl.textContent = active.dataset.title || '';
			if (priceEl) priceEl.textContent = active.dataset.price || '';
			if (linkEl && active.dataset.url) linkEl.setAttribute('href', active.dataset.url);

			const isSmall = window.matchMedia('(max-width: 749px)').matches;
			if (isSmall) {
				active.scrollIntoView({ behavior: 'smooth', inline: 'start', block: 'nearest' });
			}
		};

		cards.forEach((card, index) => {
			card.addEventListener('click', () => setActive(index));
			card.addEventListener('mouseenter', () => setActive(index));
			card.addEventListener('focusin', () => setActive(index));
		});

		if (nextButton) {
			nextButton.addEventListener('click', () => {
				setActive(activeIndex + 1);
			});
		}

		setActive(activeIndex);
	})();
</script>

{% stylesheet %}
	.feature-products {
		background: var(--fp-bg);
		padding-top: clamp(24px, var(--fp-padding-top), 96px);
		padding-bottom: clamp(24px, var(--fp-padding-bottom), 96px);
	}

	.feature-products__inner {
		--fp-page-margin: 16px;
		width: min(var(--narrow-page-width), calc(100% - (var(--fp-page-margin) * 2)));
		margin-inline: auto;
	}

	@media screen and (min-width: 750px) {
		.feature-products__inner {
			--fp-page-margin: 40px;
		}
	}

	.feature-products__head {
		display: flex;
		justify-content: space-between;
		align-items: flex-end;
		gap: 1rem;
		margin-bottom: 1.75rem;
	}

	.feature-products__heading {
		margin: 0;
		color: var(--fp-heading);
		font-size: clamp(2rem, 4vw, 3.5rem);
		line-height: 1.05;
	}

	.feature-products__subheading {
		margin: 0.75rem 0 0;
		color: var(--fp-text);
		font-size: clamp(1rem, 1.5vw, 1.45rem);
		max-width: 44ch;
	}

	.feature-products__next {
		width: 3rem;
		height: 3rem;
		border-radius: 999px;
		border: 1px solid rgb(255 255 255 / 0.7);
		color: rgb(255 255 255);
		background: transparent;
		font-size: 1.3rem;
		cursor: pointer;
		flex: 0 0 auto;
	}

	.feature-products__carousel {
		display: flex;
		gap: var(--fp-card-gap);
		align-items: stretch;
		margin-bottom: 0.9rem;
	}

	.feature-products__card {
		flex: var(--fp-collapsed-flex);
		min-width: 0;
		height: clamp(220px, 34vw, 475px);
		transition: flex 280ms ease, filter 200ms ease;
		cursor: pointer;
		filter: opacity(0.75);
	}

	.feature-products__card:hover {
		filter: opacity(1);
	}

	.feature-products__card.is-active {
		flex: var(--fp-expanded-flex);
		filter: opacity(1);
	}

	.feature-products__card-link {
		display: block;
		text-decoration: none;
		height: 100%;
	}

	.feature-products__media-wrap {
		position: relative;
		border-radius: var(--fp-card-radius);
		overflow: hidden;
		height: 100%;
	}

	.feature-products__image {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	.feature-products__image--placeholder {
		color: rgb(255 255 255 / 0.4);
		background: rgb(255 255 255 / 0.08);
	}

	.feature-products__badge {
		position: absolute;
		top: 0.9rem;
		left: 0.9rem;
		background: rgb(15 15 15 / 0.85);
		color: rgb(255 255 255);
		border-radius: 999px;
		padding: 0.4rem 0.95rem;
		font-size: 0.95rem;
		line-height: 1;
	}

	.feature-products__details {
		color: var(--fp-text);
		margin-top: 0;
	}

	.feature-products__title {
		margin: 0;
		font-size: clamp(1.4rem, 2.4vw, 2.2rem);
		line-height: 1.15;
		color: var(--fp-heading);
	}

	.feature-products__price {
		margin: 0.4rem 0 0;
		font-size: clamp(1.2rem, 2vw, 1.9rem);
		color: var(--fp-heading);
	}

	.feature-products__cta {
		margin-top: 1rem;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 8rem;
		min-height: 2.9rem;
		border: 1px solid rgb(255 255 255 / 0.75);
		color: var(--fp-button-text);
		background: var(--fp-button-bg);
		text-decoration: none;
		padding: 0.2rem 1rem;
		font-size: 1.05rem;
	}

	.feature-products__empty {
		margin: 0;
		font-size: 1rem;
		color: var(--fp-text);
	}

	@media screen and (max-width: 999px) {
		.feature-products__carousel {
			gap: max(8px, calc(var(--fp-card-gap) * 0.75));
		}
	}

	@media screen and (max-width: 749px) {
		.feature-products__head {
			align-items: center;
			margin-bottom: 1.1rem;
		}

		.feature-products__next {
			width: 2.6rem;
			height: 2.6rem;
		}

		.feature-products__carousel {
			overflow-x: auto;
			scroll-snap-type: x mandatory;
			padding-bottom: 0.35rem;
			-webkit-overflow-scrolling: touch;
			scrollbar-width: none;
			-ms-overflow-style: none;
		}

		.feature-products__carousel::-webkit-scrollbar {
			display: none;
		}

		.feature-products__card {
			flex: 0 0 72%;
			scroll-snap-align: start;
			height: clamp(210px, 74vw, 420px);
			filter: opacity(0.75);
		}

		.feature-products__card:hover {
			filter: opacity(1);
		}

		.feature-products__card.is-active {
			flex: 0 0 72%;
			scroll-snap-align: start;
			filter: opacity(1);
		}

		.feature-products__details {
			margin-top: 0.35rem;
		}
	}
{% endstylesheet %}

{% schema %}
{
	"name": "Feature product strip",
	"tag": "section",
	"class": "section-wrapper",
	"max_blocks": 12,
	"settings": [
		{
			"type": "text",
			"id": "heading",
			"label": "Heading",
			"default": "Featured Products"
		},
		{
			"type": "text",
			"id": "subheading",
			"label": "Subheading",
			"default": "Premium products curated by our AI engine, tailored to global market demands and quality standards."
		},
		{
			"type": "text",
			"id": "button_label",
			"label": "Button label",
			"default": "Shop now"
		},
		{
			"type": "color_scheme",
			"id": "color_scheme",
			"label": "Color scheme",
			"default": "scheme-1"
		},
		{
			"type": "header",
			"content": "Colors"
		},
		{
			"type": "color",
			"id": "background_color",
			"label": "Background",
			"default": "#745862"
		},
		{
			"type": "color",
			"id": "heading_color",
			"label": "Heading and price color",
			"default": "#FFFFFF"
		},
		{
			"type": "color",
			"id": "text_color",
			"label": "Subheading color",
			"default": "#F4EDEE"
		},
		{
			"type": "color",
			"id": "button_bg",
			"label": "Button background",
			"default": "transparent"
		},
		{
			"type": "color",
			"id": "button_text",
			"label": "Button text",
			"default": "#FFFFFF"
		},
		{
			"type": "header",
			"content": "Layout"
		},
		{
			"type": "range",
			"id": "expanded_ratio",
			"label": "Active card width ratio",
			"min": 12,
			"max": 30,
			"step": 1,
			"default": 22
		},
		{
			"type": "range",
			"id": "collapsed_ratio",
			"label": "Other cards width ratio",
			"min": 5,
			"max": 14,
			"step": 1,
			"default": 10
		},
		{
			"type": "range",
			"id": "card_gap",
			"label": "Card gap",
			"min": 4,
			"max": 28,
			"step": 1,
			"unit": "px",
			"default": 8
		},
		{
			"type": "range",
			"id": "card_radius",
			"label": "Card corner radius",
			"min": 0,
			"max": 30,
			"step": 1,
			"unit": "px",
			"default": 6
		},
		{
			"type": "range",
			"id": "padding_top",
			"label": "Top padding",
			"min": 0,
			"max": 140,
			"step": 2,
			"unit": "px",
			"default": 60
		},
		{
			"type": "range",
			"id": "padding_bottom",
			"label": "Bottom padding",
			"min": 0,
			"max": 140,
			"step": 2,
			"unit": "px",
			"default": 60
		}
	],
	"blocks": [
		{
			"type": "product",
			"name": "Product",
			"settings": [
				{
					"type": "product",
					"id": "product",
					"label": "Choose product"
				},
				{
					"type": "text",
					"id": "badge_text",
					"label": "Badge text",
					"default": "New"
				}
			]
		}
	],
	"presets": [
		{
			"name": "Feature product strip",
			"blocks": [
				{
					"type": "product"
				},
				{
					"type": "product"
				},
				{
					"type": "product"
				},
				{
					"type": "product"
				}
			]
		}
	]
}
{% endschema %}
