{% liquid
  assign has_slides = false
  if section.blocks.size > 0
    assign has_slides = true
  endif

  assign autoplay = section.settings.autoplay
  assign autoplay_ms = section.settings.autoplay_speed | times: 1000

  # Support both new numeric heights and legacy string values from older hero schema.
  assign desktop_height_css = '78svh'
  assign mobile_height_css = '78svh'

  assign desktop_height_numeric = section.settings.section_height | plus: 0
  if desktop_height_numeric >= 40
    assign desktop_height_css = desktop_height_numeric | append: 'svh'
  else
    case section.settings.section_height
      when 'small'
        assign desktop_height_css = '70svh'
      when 'medium'
        assign desktop_height_css = '82svh'
      when 'large'
        assign desktop_height_css = '95svh'
      when 'full-screen'
        assign desktop_height_css = '100svh'
      when 'custom'
        assign legacy_custom = section.settings.section_height_custom | plus: 0
        if legacy_custom > 0
          assign desktop_height_css = legacy_custom | append: 'svh'
        endif
    endcase
  endif

  assign mobile_height_numeric = section.settings.section_height_mobile | plus: 0
  if mobile_height_numeric >= 40
    assign mobile_height_css = mobile_height_numeric | append: 'svh'
  else
    assign mobile_height_css = desktop_height_css
  endif
%}

<section
  id="HeroSlider-{{ section.id }}"
  class="hero-slider color-{{ section.settings.color_scheme }}"
  data-autoplay="{{ autoplay }}"
  data-autoplay-speed="{{ autoplay_ms }}"
  style="
    --hero-slider-height: {{ desktop_height_css }};
    --hero-slider-height-mobile: {{ mobile_height_css }};
    --hero-overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --hero-glass-opacity: {{ section.settings.glass_opacity | divided_by: 100.0 }};
    --hero-glass-blur: {{ section.settings.glass_blur }}px;
    --hero-card-width: {{ section.settings.card_width }}px;
    --hero-content-max-width: {{ section.settings.content_max_width }}px;
    --hero-content-offset: {{ section.settings.content_top_offset | default: 110 }}px;
    --hero-content-offset-mobile: {{ section.settings.content_top_offset_mobile | default: 24 }}px;
  "
>
  <div class="hero-slider__viewport" data-testid="hero-slider-viewport">
    {% if has_slides %}
      {% for block in section.blocks %}
        {% liquid
          assign slide_image = block.settings.background_image
          assign slide_mobile_image = block.settings.background_image_mobile
          assign has_slide_content = false
          if block.settings.eyebrow != blank or block.settings.heading != blank or block.settings.description != blank
            assign has_slide_content = true
          endif
          if block.settings.button_label != blank and block.settings.button_link != blank
            assign has_slide_content = true
          endif
          assign post_url = block.settings.social_url | strip
          assign social_platform = block.settings.social_platform
          assign embed_url = ''

          if social_platform == 'auto'
            if post_url contains 'instagram.com'
              assign social_platform = 'instagram'
            elsif post_url contains 'facebook.com' or post_url contains 'fb.watch'
              assign social_platform = 'facebook'
            else
              assign social_platform = 'none'
            endif
          endif

          if post_url != blank and block.settings.social_enable_embed
            if social_platform == 'instagram'
              if post_url contains '/reel/'
                assign ig_id = post_url | split: '/reel/' | last | split: '/' | first | split: '?' | first
                assign embed_url = 'https://www.instagram.com/reel/' | append: ig_id | append: '/embed'
              elsif post_url contains '/p/'
                assign ig_id = post_url | split: '/p/' | last | split: '/' | first | split: '?' | first
                assign embed_url = 'https://www.instagram.com/p/' | append: ig_id | append: '/embed'
              elsif post_url contains '/tv/'
                assign ig_id = post_url | split: '/tv/' | last | split: '/' | first | split: '?' | first
                assign embed_url = 'https://www.instagram.com/tv/' | append: ig_id | append: '/embed'
              endif
            elsif social_platform == 'facebook'
              assign embed_url = 'https://www.facebook.com/plugins/post.php?href=' | append: post_url | url_encode | append: '&show_text=false&width=500'
            endif
          endif
        %}

        <article
          class="hero-slide{% if forloop.first %} is-active{% endif %}"
          data-slide-index="{{ forloop.index0 }}"
          {{ block.shopify_attributes }}
        >
          <div class="hero-slide__media" data-testid="hero-slide-media">
            {% if slide_image != blank and slide_mobile_image != blank %}
              <picture>
                <source media="(max-width: 749px)" srcset="{{ slide_mobile_image | image_url: width: 1200 }}">
                {{
                  slide_image
                  | image_url: width: 3200
                  | image_tag:
                    widths: '800, 1200, 1600, 2200, 3200',
                    sizes: '100vw',
                    loading: 'eager',
                    fetchpriority: 'high',
                    alt: slide_image.alt,
                    class: 'hero-slide__image'
                }}
              </picture>
            {% elsif slide_image != blank %}
              {{
                slide_image
                | image_url: width: 3200
                | image_tag:
                  widths: '800, 1200, 1600, 2200, 3200',
                  sizes: '100vw',
                  loading: 'eager',
                  fetchpriority: 'high',
                  alt: slide_image.alt,
                  class: 'hero-slide__image'
              }}
            {% else %}
              {{ 'hero-apparel-1' | placeholder_svg_tag: 'hero-slide__image hero-slide__image--placeholder' }}
            {% endif %}
            <div class="hero-slide__overlay"></div>
          </div>

          <div class="hero-slide__content-wrap page-width{% if has_slide_content == false and block.settings.show_social_card %} hero-slide__content-wrap--social-only{% endif %}">
            {% if has_slide_content %}
              <div class="hero-slide__content glass-panel" data-testid="hero-content-panel">
                {% if block.settings.eyebrow != blank %}
                  <p class="hero-slide__eyebrow">{{ block.settings.eyebrow }}</p>
                {% endif %}

                {% if block.settings.heading != blank %}
                  <h2 class="hero-slide__heading">{{ block.settings.heading }}</h2>
                {% endif %}

                {% if block.settings.description != blank %}
                  <div class="hero-slide__description rte">{{ block.settings.description }}</div>
                {% endif %}

                {% if block.settings.button_label != blank and block.settings.button_link != blank %}
                  <a href="{{ block.settings.button_link }}" class="hero-slide__button button button--primary">
                    {{ block.settings.button_label }}
                  </a>
                {% endif %}
              </div>
            {% endif %}

            {% if block.settings.show_social_card %}
              <aside class="hero-slide__social glass-panel" data-testid="hero-social-card">
                <div class="hero-slide__social-head">
                  <p class="hero-slide__social-title">{{ block.settings.social_card_title }}</p>
                  {% if block.settings.social_card_tag != blank %}
                    <span class="hero-slide__social-tag">{{ block.settings.social_card_tag }}</span>
                  {% endif %}
                </div>

                <div class="hero-slide__social-body">
                  {% if embed_url != blank %}
                    <iframe
                      class="hero-slide__social-embed"
                      src="{{ embed_url }}"
                      title="Social post embed"
                      loading="lazy"
                      allowfullscreen
                      referrerpolicy="strict-origin-when-cross-origin"
                    ></iframe>
                  {% elsif block.settings.social_preview_image != blank %}
                    {{
                      block.settings.social_preview_image
                      | image_url: width: 1200
                      | image_tag:
                        widths: '320, 480, 640, 960, 1200',
                        sizes: '(max-width: 749px) 70vw, 360px',
                        loading: 'lazy',
                        alt: block.settings.social_card_title,
                        class: 'hero-slide__social-image'
                    }}
                  {% else %}
                    <div class="hero-slide__social-fallback">
                      <p>Paste an Instagram or Facebook post URL to render it here.</p>
                    </div>
                  {% endif %}
                </div>

                {% liquid
                  assign social_link = block.settings.social_link
                  if social_link == blank
                    assign social_link = post_url
                  endif
                %}
                {% if social_link != blank and block.settings.social_link_label != blank %}
                  <a href="{{ social_link }}" class="hero-slide__social-link" target="_blank" rel="noopener">
                    {{ block.settings.social_link_label }}
                  </a>
                {% endif %}
              </aside>
            {% endif %}
          </div>
        </article>
      {% endfor %}
    {% else %}
      <article class="hero-slide is-active">
        <div class="hero-slide__media">
          {{ 'hero-apparel-1' | placeholder_svg_tag: 'hero-slide__image hero-slide__image--placeholder' }}
          <div class="hero-slide__overlay"></div>
        </div>
        <div class="hero-slide__content-wrap page-width">
          <div class="hero-slide__content glass-panel">
            <h2 class="hero-slide__heading">Add hero slides from the theme editor</h2>
            <p class="hero-slide__description">Each slide supports editable content, media, and social card settings.</p>
          </div>
        </div>
      </article>
    {% endif %}
  </div>

  {% if section.blocks.size > 1 %}
    {% if section.settings.show_arrows %}
      <button type="button" class="hero-slider__arrow hero-slider__arrow--prev" data-action="prev" aria-label="Previous slide">
        <span>&larr;</span>
      </button>
      <button type="button" class="hero-slider__arrow hero-slider__arrow--next" data-action="next" aria-label="Next slide">
        <span>&rarr;</span>
      </button>
    {% endif %}

    {% if section.settings.show_dots %}
      <div class="hero-slider__dots" role="tablist" aria-label="Hero slides">
        {% for block in section.blocks %}
          <button
            type="button"
            role="tab"
            class="hero-slider__dot{% if forloop.first %} is-active{% endif %}"
            data-dot-index="{{ forloop.index0 }}"
            aria-label="Go to slide {{ forloop.index }}"
            aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
          ></button>
        {% endfor %}
      </div>
    {% endif %}
  {% endif %}
</section>

<script>
  (() => {
    const sectionEl = document.getElementById('HeroSlider-{{ section.id }}');
    if (!sectionEl) return;

    const slides = [...sectionEl.querySelectorAll('.hero-slide')];
    if (slides.length <= 1) return;

    const dots = [...sectionEl.querySelectorAll('.hero-slider__dot')];
    const prevButton = sectionEl.querySelector('[data-action="prev"]');
    const nextButton = sectionEl.querySelector('[data-action="next"]');

    const autoplay = sectionEl.dataset.autoplay === 'true';
    const autoplaySpeed = Number(sectionEl.dataset.autoplaySpeed) || 5000;

    let activeIndex = 0;
    let timerId = null;

    const setActiveSlide = (index) => {
      activeIndex = (index + slides.length) % slides.length;

      slides.forEach((slide, slideIndex) => {
        slide.classList.toggle('is-active', slideIndex === activeIndex);
      });

      dots.forEach((dot, dotIndex) => {
        const isActive = dotIndex === activeIndex;
        dot.classList.toggle('is-active', isActive);
        dot.setAttribute('aria-selected', isActive ? 'true' : 'false');
      });
    };

    const startAutoplay = () => {
      if (!autoplay) return;
      stopAutoplay();
      timerId = window.setInterval(() => {
        setActiveSlide(activeIndex + 1);
      }, autoplaySpeed);
    };

    const stopAutoplay = () => {
      if (timerId) {
        window.clearInterval(timerId);
        timerId = null;
      }
    };

    if (prevButton) {
      prevButton.addEventListener('click', () => {
        setActiveSlide(activeIndex - 1);
        startAutoplay();
      });
    }

    if (nextButton) {
      nextButton.addEventListener('click', () => {
        setActiveSlide(activeIndex + 1);
        startAutoplay();
      });
    }

    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        const dotIndex = Number(dot.dataset.dotIndex);
        if (!Number.isNaN(dotIndex)) {
          setActiveSlide(dotIndex);
          startAutoplay();
        }
      });
    });

    sectionEl.addEventListener('mouseenter', stopAutoplay);
    sectionEl.addEventListener('mouseleave', startAutoplay);

    setActiveSlide(0);
    startAutoplay();
  })();
</script>

{% stylesheet %}
  .hero-slider {
    position: relative;
    min-height: var(--hero-slider-height-mobile);
    overflow: hidden;
    isolation: isolate;

    @media screen and (min-width: 750px) {
      min-height: var(--hero-slider-height);
    }
  }

  .hero-slider__viewport {
    min-height: inherit;
    position: relative;
  }

  .hero-slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    visibility: hidden;
    transition: opacity 500ms ease;
    min-height: inherit;
    pointer-events: none;
  }

  .hero-slide.is-active {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  .hero-slide__media,
  .hero-slide__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: -2;
  }

  .hero-slide__image--placeholder {
    color: rgb(var(--color-foreground-rgb) / 0.12);
  }

  .hero-slide__overlay {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 80% 20%, rgb(255 255 255 / 0.18), transparent 40%),
      linear-gradient(to bottom, rgb(7 3 8 / 0.3), rgb(7 3 8 / 0.5));
    opacity: var(--hero-overlay-opacity);
    z-index: -1;
  }

  .hero-slide__content-wrap {
    position: relative;
    min-height: inherit;
    display: grid;
    align-items: end;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    padding-top: 2.5rem;
    padding-bottom: 2.5rem;

    @media screen and (min-width: 750px) {
      align-items: start;
      grid-template-columns: minmax(280px, var(--hero-content-max-width)) minmax(260px, var(--hero-card-width));
      justify-content: space-between;
      gap: 2rem;
      padding-top: 3rem;
      padding-bottom: 3rem;
    }
  }

  @media screen and (min-width: 750px) {
    .hero-slide__content-wrap--social-only {
      grid-template-columns: 1fr;
      justify-items: end;
    }
  }

  .glass-panel {
    background: linear-gradient(145deg, rgb(255 255 255 / calc(var(--hero-glass-opacity) + 0.08)), rgb(255 255 255 / calc(var(--hero-glass-opacity) - 0.04)));
    border: 1px solid rgb(255 255 255 / 0.35);
    box-shadow:
      0 0.5rem 2rem rgb(0 0 0 / 0.16),
      inset 0 1px 0 rgb(255 255 255 / 0.38);
    backdrop-filter: blur(var(--hero-glass-blur)) saturate(145%);
    -webkit-backdrop-filter: blur(var(--hero-glass-blur)) saturate(145%);
  }

  .hero-slide__content {
    border-radius: 1.4rem;
    padding: 1.2rem 1.2rem 1.4rem;
    color: rgb(var(--color-foreground-rgb));
    margin-top: 0;
    transform: translateY(var(--hero-content-offset-mobile));

    @media screen and (min-width: 750px) {
      padding: 1.6rem 1.7rem 1.8rem;
      margin-top: 0;
      transform: translateY(var(--hero-content-offset));
    }
  }

  .hero-slide__eyebrow {
    margin: 0 0 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.72rem;
    font-weight: 600;
    opacity: 0.88;
  }

  .hero-slide__heading {
    margin: 0;
    font-size: clamp(1.5rem, 3vw, 3.2rem);
    line-height: 1.08;
    text-wrap: balance;
  }

  .hero-slide__description {
    margin-top: 0.9rem;
    font-size: clamp(0.9rem, 1.45vw, 1.05rem);
    max-width: 48ch;
  }

  .hero-slide__button {
    margin-top: 1.2rem;
  }

  .hero-slide__social {
    width: 100%;
    max-width: min(100%, var(--hero-card-width));
    border-radius: 1.2rem;
    padding: 1rem;
    justify-self: end;
    align-self: end;
  }


  @media screen and (min-width: 750px) {
    .hero-slide__social {
      margin-bottom: 0.75rem;
      transform: translateY(1rem);
    }
  }
  .hero-slide__social-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.7rem;
  }

  .hero-slide__social-title {
    margin: 0;
    font-size: 0.98rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .hero-slide__social-tag {
    font-size: 0.72rem;
    border: 1px solid rgb(255 255 255 / 0.38);
    border-radius: 999px;
    padding: 0.2rem 0.55rem;
    background: rgb(255 255 255 / 0.14);
  }

  .hero-slide__social-body {
    border-radius: 0.95rem;
    overflow: hidden;
    background: rgb(255 255 255 / 0.2);
    min-height: 300px;
  }

  .hero-slide__social-embed,
  .hero-slide__social-image {
    display: block;
    width: 100%;
    min-height: 300px;
    height: 100%;
    border: 0;
    object-fit: cover;
    background: rgb(0 0 0 / 0.2);
  }

  .hero-slide__social-fallback {
    min-height: 300px;
    display: grid;
    place-items: center;
    padding: 1rem;
    text-align: center;
    font-size: 0.92rem;
    opacity: 0.9;
  }

  .hero-slide__social-link {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    margin-top: 0.7rem;
    font-weight: 600;
    text-decoration: none;
  }

  .hero-slider__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 3;
    width: 2.7rem;
    height: 2.7rem;
    border-radius: 999px;
    border: 1px solid rgb(255 255 255 / 0.4);
    background: rgb(16 12 16 / 0.36);
    color: rgb(255 255 255);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    cursor: pointer;

    @media screen and (max-width: 749px) {
      width: 2.3rem;
      height: 2.3rem;
    }
  }

  .hero-slider__arrow--prev {
    left: 1rem;

    @media screen and (min-width: 750px) {
      left: 1.6rem;
    }
  }

  .hero-slider__arrow--next {
    right: 1rem;

    @media screen and (min-width: 750px) {
      right: 1.6rem;
    }
  }

  .hero-slider__dots {
    position: absolute;
    left: 50%;
    bottom: 1.1rem;
    transform: translateX(-50%);
    z-index: 3;
    display: inline-flex;
    gap: 0.5rem;
    padding: 0.45rem 0.65rem;
    border-radius: 999px;
    background: rgb(16 12 16 / 0.4);
    border: 1px solid rgb(255 255 255 / 0.25);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .hero-slider__dot {
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 999px;
    border: 0;
    background: rgb(255 255 255 / 0.4);
    cursor: pointer;
    transition: transform 160ms ease, background-color 160ms ease;
  }

  .hero-slider__dot.is-active {
    background: rgb(255 255 255);
    transform: scale(1.12);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Hero slider",
  "tag": "section",
  "class": "hero-slider-wrapper section-wrapper",
  "max_blocks": 8,
  "disabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "section_height",
      "label": "Desktop height",
      "options": [
        {
          "value": "small",
          "label": "Small"
        },
        {
          "value": "medium",
          "label": "Medium"
        },
        {
          "value": "large",
          "label": "Large"
        },
        {
          "value": "full-screen",
          "label": "Full screen"
        },
        {
          "value": "custom",
          "label": "Custom"
        }
      ],
      "default": "full-screen"
    },
    {
      "type": "range",
      "id": "section_height_custom",
      "label": "Desktop custom height",
      "min": 40,
      "max": 100,
      "step": 1,
      "unit": "vh",
      "default": 78,
      "visible_if": "{{ section.settings.section_height == 'custom' }}"
    },
    {
      "type": "range",
      "id": "section_height_mobile",
      "label": "Mobile height",
      "min": 45,
      "max": 100,
      "step": 1,
      "unit": "vh",
      "default": 92
    },
    {
      "type": "range",
      "id": "content_max_width",
      "label": "Content max width",
      "min": 320,
      "max": 900,
      "step": 10,
      "unit": "px",
      "default": 700
    },
    {
      "type": "range",
      "id": "content_top_offset",
      "label": "Content top offset (desktop)",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "default": 110
    },
    {
      "type": "range",
      "id": "content_top_offset_mobile",
      "label": "Content top offset (mobile)",
      "min": 0,
      "max": 140,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "card_width",
      "label": "Social card width",
      "min": 220,
      "max": 480,
      "step": 10,
      "unit": "px",
      "default": 330
    },
    {
      "type": "header",
      "content": "Overlay and glass"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 62
    },
    {
      "type": "range",
      "id": "glass_opacity",
      "label": "Glass opacity",
      "min": 5,
      "max": 70,
      "step": 1,
      "unit": "%",
      "default": 24
    },
    {
      "type": "range",
      "id": "glass_blur",
      "label": "Glass blur",
      "min": 2,
      "max": 36,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "header",
      "content": "Slider controls"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Autoplay speed",
      "min": 3,
      "max": 12,
      "step": 1,
      "unit": "s",
      "default": 6
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show arrows",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "Show dots",
      "default": true
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-5"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "header",
          "content": "Background"
        },
        {
          "type": "image_picker",
          "id": "background_image",
          "label": "Background image"
        },
        {
          "type": "image_picker",
          "id": "background_image_mobile",
          "label": "Mobile background image"
        },
        {
          "type": "header",
          "content": "Content"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow",
          "default": "New Collection"
        },
