<section
	id="WhyUs-{{ section.id }}"
	class="why-us color-{{ section.settings.color_scheme }}"
	style="
		--wu-bg: {{ section.settings.background_color }};
		--wu-heading: {{ section.settings.heading_color }};
		--wu-subheading: {{ section.settings.subheading_color }};
		--wu-card-bg: {{ section.settings.card_background }};
		--wu-card-border: {{ section.settings.card_border_color }};
		--wu-icon: {{ section.settings.icon_color }};
		--wu-title: {{ section.settings.card_title_color }};
		--wu-text: {{ section.settings.card_text_color }};
		--wu-radius: {{ section.settings.card_radius }}px;
		--wu-gap: {{ section.settings.card_gap }}px;
		--wu-padding-top: {{ section.settings.padding_top }}px;
		--wu-padding-bottom: {{ section.settings.padding_bottom }}px;
	"
>
	<div class="page-width-normal why-us__inner">
		{% if section.settings.heading != blank or section.settings.subheading != blank %}
			<header class="why-us__header">
				{% if section.settings.heading != blank %}
					<h2 class="why-us__heading">{{ section.settings.heading }}</h2>
				{% endif %}
				{% if section.settings.subheading != blank %}
					<p class="why-us__subheading">{{ section.settings.subheading }}</p>
				{% endif %}
			</header>
		{% endif %}

		{% if section.blocks.size > 0 %}
			<div class="why-us__grid">
				{% for block in section.blocks %}
					<article class="why-us__card" {{ block.shopify_attributes }}>
						<div class="why-us__icon-wrap" aria-hidden="true">
							{% if block.settings.custom_icon != blank %}
								{{
									block.settings.custom_icon
									| image_url: width: 120
									| image_tag:
										widths: '60, 90, 120',
										sizes: '42px',
										class: 'why-us__icon-image',
										loading: 'lazy',
										alt: block.settings.title
								}}
							{% else %}
								{% case block.settings.icon %}
									{% when 'global' %}
										<svg class="why-us__icon" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
											<circle cx="24" cy="24" r="14"></circle>
											<path d="M10 24h28"></path>
											<path d="M24 10c4.5 4.2 7 8.9 7 14s-2.5 9.8-7 14c-4.5-4.2-7-8.9-7-14s2.5-9.8 7-14Z"></path>
											<path d="M6 18h6"></path>
											<path d="M6 30h6"></path>
											<path d="M36 18h6"></path>
											<path d="M36 30h6"></path>
										</svg>
									{% when 'export' %}
										<svg class="why-us__icon" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
											<circle cx="21" cy="23" r="13"></circle>
											<path d="M21 10c4.2 4 6.4 8.4 6.4 13S25.2 32 21 36c-4.2-4-6.4-8.4-6.4-13S16.8 14 21 10Z"></path>
											<path d="M8 23h26"></path>
											<path d="M30 15l10 0"></path>
											<path d="M35 10l5 5-5 5"></path>
											<path d="M6 33h6"></path>
											<path d="M9 30v6"></path>
										</svg>
									{% when 'quality' %}
										<svg class="why-us__icon" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
											<path d="M24 7l11 4v8c0 8.8-4.7 14.4-11 18-6.3-3.6-11-9.2-11-18v-8l11-4Z"></path>
											<path d="M19.5 24l3.3 3.3L29 21"></path>
											<path d="M10 17l-3 3"></path>
											<path d="M9 27H5"></path>
										</svg>
									{% else %}
										<svg class="why-us__icon" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
											<circle cx="24" cy="24" r="4"></circle>
											<path d="M24 7v6"></path>
											<path d="M24 35v6"></path>
											<path d="M7 24h6"></path>
											<path d="M35 24h6"></path>
											<path d="M12.7 12.7l4.2 4.2"></path>
											<path d="M31.1 31.1l4.2 4.2"></path>
											<path d="M35.3 12.7l-4.2 4.2"></path>
											<path d="M16.9 31.1l-4.2 4.2"></path>
											<circle cx="24" cy="10" r="1.4" fill="currentColor" stroke="none"></circle>
											<circle cx="24" cy="38" r="1.4" fill="currentColor" stroke="none"></circle>
											<circle cx="10" cy="24" r="1.4" fill="currentColor" stroke="none"></circle>
											<circle cx="38" cy="24" r="1.4" fill="currentColor" stroke="none"></circle>
										</svg>
								{% endcase %}
							{% endif %}
						</div>

						<div class="why-us__content">
							{% if block.settings.title != blank %}
								<h3 class="why-us__card-title">{{ block.settings.title }}</h3>
							{% endif %}
							{% if block.settings.text != blank %}
								<p class="why-us__card-text">{{ block.settings.text }}</p>
							{% endif %}
						</div>
					</article>
				{% endfor %}
			</div>
		{% else %}
			<p class="why-us__empty">Add cards in the editor to build this section.</p>
		{% endif %}
	</div>
</section>

{% stylesheet %}
	.why-us {
		background: var(--wu-bg);
		padding-top: var(--wu-padding-top);
		padding-bottom: var(--wu-padding-bottom);
	}

	.why-us__inner {
		--wu-page-margin: 16px;
		width: min(var(--narrow-page-width), calc(100% - (var(--wu-page-margin) * 2)));
		margin-inline: auto;
	}

	@media screen and (min-width: 750px) {
		.why-us__inner {
			--wu-page-margin: 40px;
		}
	}

	.why-us__header {
		margin-bottom: 2rem;
	}

	.why-us__heading {
		margin: 0;
		color: var(--wu-heading);
		font-size: clamp(2.2rem, 4vw, 3.6rem);
		line-height: 1.05;
		letter-spacing: -0.03em;
	}

	.why-us__subheading {
		margin: 0.55rem 0 0;
		color: var(--wu-subheading);
		font-size: clamp(1rem, 1.45vw, 1.35rem);
		line-height: 1.35;
	}

	.why-us__grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: var(--wu-gap);
	}

	.why-us__card {
		display: grid;
		grid-template-columns: 4rem minmax(0, 1fr);
		align-items: start;
		gap: 1rem;
		min-height: 8.5rem;
		padding: 1.9rem 2rem;
		background: var(--wu-card-bg);
		border: 1px solid var(--wu-card-border);
		border-radius: var(--wu-radius);
	}

	.why-us__icon-wrap {
		width: 3.6rem;
		height: 3.6rem;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		color: var(--wu-icon);
		flex: 0 0 auto;
	}

	.why-us__icon,
	.why-us__icon-image {
		width: 2.7rem;
		height: 2.7rem;
		display: block;
	}

	.why-us__icon-image {
		object-fit: contain;
	}

	.why-us__content {
		min-width: 0;
	}

	.why-us__card-title {
		margin: 0;
		color: var(--wu-title);
		font-size: clamp(1.35rem, 1.55vw, 1.85rem);
		line-height: 1.2;
		font-weight: 700;
	}

	.why-us__card-text {
		margin: 0.55rem 0 0;
		color: var(--wu-text);
		font-size: clamp(1.05rem, 1.3vw, 1.25rem);
		line-height: 1.35;
		max-width: 22ch;
	}

	.why-us__empty {
		margin: 0;
		color: var(--wu-text);
		font-size: 1rem;
	}

	@media screen and (max-width: 749px) {
		.why-us__grid {
			grid-template-columns: 1fr;
		}

		.why-us__card {
			grid-template-columns: 3.25rem minmax(0, 1fr);
			padding: 1.35rem 1.2rem;
			gap: 0.85rem;
			min-height: auto;
		}

		.why-us__icon-wrap {
			width: 3rem;
			height: 3rem;
		}

		.why-us__icon,
		.why-us__icon-image {
			width: 2.25rem;
			height: 2.25rem;
		}
	}
{% endstylesheet %}

{% schema %}
{
	"name": "Why us",
	"tag": "section",
	"class": "section-wrapper",
	"settings": [
		{
			"type": "text",
			"id": "heading",
			"label": "Heading",
			"default": "Why Choose Bluekites"
		},
		{
			"type": "text",
			"id": "subheading",
			"label": "Subheading",
			"default": "Multiple Industries, One mutual Network"
		},
		{
			"type": "color_scheme",
			"id": "color_scheme",
			"label": "Color scheme",
			"default": "scheme-1"
		},
		{
			"type": "header",
			"content": "Colors"
		},
		{
			"type": "color",
			"id": "background_color",
			"label": "Background",
			"default": "#FCFBFA"
		},
		{
			"type": "color",
			"id": "heading_color",
			"label": "Heading color",
			"default": "#3A1E25"
		},
		{
			"type": "color",
			"id": "subheading_color",
			"label": "Subheading color",
			"default": "#4A2A30"
		},
		{
			"type": "color",
			"id": "card_background",
			"label": "Card background",
			"default": "#FFFFFF"
		},
		{
			"type": "color",
			"id": "card_border_color",
			"label": "Card border",
			"default": "#DCCFD0"
		},
		{
			"type": "color",
			"id": "icon_color",
			"label": "Icon color",
			"default": "#4A242C"
		},
		{
			"type": "color",
			"id": "card_title_color",
			"label": "Card title color",
			"default": "#3A1E25"
		},
		{
			"type": "color",
			"id": "card_text_color",
			"label": "Card text color",
			"default": "#4A2A30"
		},
		{
			"type": "header",
			"content": "Layout"
		},
		{
			"type": "range",
			"id": "card_gap",
			"label": "Card gap",
			"min": 8,
			"max": 32,
			"step": 2,
			"default": 10
		},
		{
			"type": "range",
			"id": "card_radius",
			"label": "Card corner radius",
			"min": 0,
			"max": 24,
			"step": 1,
			"default": 0
		},
		{
			"type": "range",
			"id": "padding_top",
			"label": "Top padding",
			"min": 0,
			"max": 160,
			"step": 4,
			"default": 56
		},
		{
			"type": "range",
			"id": "padding_bottom",
			"label": "Bottom padding",
			"min": 0,
			"max": 160,
			"step": 4,
			"default": 56
		}
	],
	"blocks": [
		{
			"type": "item",
			"name": "Card",
			"settings": [
				{
					"type": "select",
					"id": "icon",
					"label": "Fallback icon",
					"default": "expertise",
					"options": [
						{
							"value": "expertise",
							"label": "Expertise"
						},
						{
							"value": "global",
							"label": "Global network"
						},
						{
							"value": "export",
							"label": "Export"
						},
						{
							"value": "quality",
							"label": "Quality"
						}
					]
				},
				{
					"type": "image_picker",
					"id": "custom_icon",
					"label": "Custom icon image"
				},
				{
					"type": "text",
					"id": "title",
					"label": "Title",
					"default": "Multi-domain Expertise"
				},
				{
					"type": "textarea",
					"id": "text",
					"label": "Description",
					"default": "Diverse business verticals for all your needs."
				}
			]
		}
	],
	"presets": [
		{
			"name": "Why us",
			"blocks": [
				{
					"type": "item",
					"settings": {
						"icon": "expertise",
						"title": "Multi-domain Expertise",
						"text": "Diverse business verticals for all your needs."
					}
				},
				{
					"type": "item",
					"settings": {
						"icon": "global",
						"title": "Global Sourcing Network",
						"text": "Strong network of manufacturers & suppliers worldwide."
					}
				},
				{
					"type": "item",
					"settings": {
						"icon": "export",
						"title": "Export Capabilities",
						"text": "Seamless export support & global logistics."
					}
				},
				{
					"type": "item",
					"settings": {
						"icon": "quality",
						"title": "Quality & Compliance",
						"text": "ISO standards, certified processes & quality assurance."
					}
				}
			]
		}
	]
}
{% endschema %}
