					"default": "US"
				},
				{
					"type": "text",
					"id": "country",
					"label": "Country name",
					"default": "USA"
				},
				{
					"type": "text",
					"id": "visa_type",
					"label": "Visa type",
					"default": "Tourist Visa"
				},
				{
					"type": "text",
					"id": "processing_time",
					"label": "Processing time",
					"default": "15-20 days"
				},
				{
					"type": "url",
					"id": "link",
					"label": "Card link"
				}
			]
		}
	],
	"max_blocks": 24,
	"presets": [
		{
			"name": "Visa assistance",
			"blocks": [
				{
					"type": "country_card",
					"settings": {
						"code": "US",
