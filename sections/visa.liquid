						"processing_time": "10-15 days"
					}
				},
				{
					"type": "country_card",
					"settings": {
						"code": "AU",
						"country": "Australia",
						"processing_time": "20-30 days"
					}
				},
				{
					"type": "country_card",
					"settings": {
						"code": "CA",
						"country": "Canada",
						"processing_time": "15-25 days"
					}
				},
				{
					"type": "country_card",
					"settings": {
						"code": "SG",
						"country": "Singapore",
						"processing_time": "3-5 days"
					}
				},
				{
					"type": "country_card",
					"settings": {
						"code": "AE",
						"country": "UAE",
						"processing_time": "2-4 days"
					}
				}
			]
		}
	]
}
{% endschema %}
